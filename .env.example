# Nigerian University MIS - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# SECURITY
# =============================================================================
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# DATABASE - PostgreSQL Only
# =============================================================================
DB_NAME=university_mis
DB_USER=umis_user
DB_PASSWORD=your-secure-database-password
DB_HOST=localhost
DB_PORT=5432
TEST_DB_NAME=test_university_mis

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET_KEY=your-jwt-secret-key
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# =============================================================================
# MINIO / S3-COMPATIBLE STORAGE
# =============================================================================
MINIO_BUCKET_NAME=umis-files
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
AWS_S3_REGION=us-east-1

# =============================================================================
# EMAIL / NOTIFICATIONS
# =============================================================================
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@umis.edu.ng
SENDGRID_API_KEY=

# =============================================================================
# MONITORING
# =============================================================================
SENTRY_DSN=
PROMETHEUS_EXPORT_PORT=9090

# =============================================================================
# CORS
# =============================================================================
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# PRODUCTION_ALLOWED_HOSTS=umis.edu.ng,www.umis.edu.ng
# STAGING_ALLOWED_HOSTS=staging.umis.edu.ng
# PRODUCTION_CORS_ORIGINS=https://umis.edu.ng
# MLFLOW_DB_NAME=mlflow